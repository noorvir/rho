{
	"name": "@rho/cli",
	"version": "0.0.0",
	"description": "Command-line interface for rho.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"rho": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsgo -b tsconfig.json",
		"typecheck": "tsgo -b tsconfig.json --pretty false",
		"clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
	},
	"dependencies": {
		"@rho/ai": "0.0.0",
		"@rho/channels": "0.0.0"
	},
	"keywords": [
		"ai",
		"agents",
		"cli"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
