{
	"name": "@rho/ai",
	"version": "0.0.0",
	"description": "AI provider integration layer for long-running agents.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsgo -b tsconfig.json",
		"typecheck": "tsgo -b tsconfig.json --pretty false",
		"clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "^0.75.5",
		"@earendil-works/pi-ai": "^0.75.5",
		"@earendil-works/pi-coding-agent": "^0.75.5"
	},
	"keywords": [
		"ai",
		"agents",
		"llm"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
