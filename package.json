{
	"name": "rho",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.5",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "tsc -b",
		"typecheck": "tsc -b --pretty false",
		"check": "biome check . && bun run typecheck",
		"format": "biome check --write .",
		"clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo packages/*/*.tsbuildinfo tsconfig.tsbuildinfo"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "^24.3.0",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
