{
	"name": "rho",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.5",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "tsgo -b",
		"rho": "bun run build && bun packages/cli/dist/cli.js",
		"typecheck": "tsgo -b --pretty false",
		"typecheck:mobile": "cd packages/mobile && bun run typecheck",
		"check": "biome check . && bun run typecheck && bun run typecheck:mobile",
		"format": "biome check --write .",
		"clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo packages/*/*.tsbuildinfo tsconfig.tsbuildinfo"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "^24.3.0",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
